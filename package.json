{
  "name": "d-league-|-台南夢達七人足球聯賽",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://dreamsportfootball.github.io/d-league",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "validate:data": "node scripts/validate-season-data.mjs",
    "generate:seo": "node scripts/generate-static-seo.mjs",
    "validate:seo": "node scripts/validate-static-seo.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "build:site": "vite build && npm run generate:seo && npm run validate:seo",
    "build": "npm run typecheck && npm run validate:data && npm run build:site",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.10",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
